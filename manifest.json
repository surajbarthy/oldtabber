{
  "manifest_version": 3,
  "name": "Tab Aging",
  "version": "1.0.0",
  "description": "Makes idle tabs feel more urgent by aging favicons and optional title markers — local-only, Manifest V3.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
